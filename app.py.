import streamlit as st
import requests

st.set_page_config(page_title="BTC Tracker", page_icon="🚀")

st.title("🚀 Bitcoin Árfolyam")

def get_price():
    try:
        url = "https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT"
        r = requests.get(url)
        return f"{float(r.json()['price']):,.2f}"
    except:
        return "Hiba az adatoknál"

if st.button('Frissítés most 🔄', use_container_width=True):
    price = get_price()
    st.metric(label="Aktuális Ár (USDT)", value=f"${price}")
else:
    st.info("Kattints a gombra az élő árhoz!")
